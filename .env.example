# Canonical site URL (metadata, sitemap, JSON-LD). Production: https://www.indonesiancafe.co.uk
NEXT_PUBLIC_APP_URL=https://www.indonesiancafe.co.uk
NEXT_PUBLIC_CONVEX_URL=
CONVEX_DEPLOYMENT=
CLERK_SECRET_KEY=
# Clerk publishable key (public, safe for client). Used by ClerkProvider.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
# Clerk JWT issuer domain for Convex auth (e.g. https://<your-clerk-domain>.clerk.accounts.dev).
# Set via Convex dashboard as CLERK_JWT_ISSUER environment variable.
CLERK_JWT_ISSUER=
