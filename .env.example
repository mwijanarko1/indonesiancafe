# Optional. On Vercel, https://$VERCEL_URL is used if empty. Production: https://indonesiancafe.vercel.app
NEXT_PUBLIC_APP_URL=
NEXT_PUBLIC_CONVEX_URL=
# Convex HTTP actions base (same slug as deployment). Admin: POST with Authorization: Bearer <MENU_ADMIN_SECRET>
CONVEX_SITE_URL=
CONVEX_DEPLOYMENT=
CLERK_SECRET_KEY=
# Set in Convex dashboard (Settings → Environment Variables). Used only for Bearer auth on *.convex.site/admin/* routes — never expose to the browser.
MENU_ADMIN_SECRET=
